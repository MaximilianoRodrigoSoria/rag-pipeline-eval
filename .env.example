# === Proveedor de generación ===
# "anthropic" (Claude, por API) o "ollama" (LLM local, sin costo).
LLM_PROVIDER=anthropic

# === Juez de evaluación (RAGAS) ===
# Desacopla el juez de la generación: podés generar local (Ollama) y juzgar con
# Claude para métricas más confiables (faithfulness/context_precision).
# Vacío = usa el mismo LLM_PROVIDER.  Valores: "" | anthropic | ollama
JUDGE_PROVIDER=
# Modelo del juez cuando es Anthropic. Vacío = usa LLM_MODEL.
# Un Haiku barato alcanza para juzgar y baja el costo (ej: claude-haiku-4-5-20251001).
JUDGE_MODEL=

# === Generación (Claude / Anthropic) ===
# Obtené tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

# === Generación (Ollama, local) — usar con LLM_PROVIDER=ollama ===
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# === Embeddings (open source, corren en local, sin costo) ===
EMBED_MODEL=intfloat/multilingual-e5-small

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=sentence

# === Retrieval ===
TOP_K=4

# === Vector store (Chroma local) ===
CHROMA_PATH=./data/processed/chroma
CHROMA_COLLECTION=rag_corpus

# === Datos ===
CORPUS_DIR=./data/raw
