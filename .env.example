# === Generación (Claude / Anthropic) ===
# Obtené tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de generación (podés subirlo a un Sonnet más nuevo cuando quieras)
LLM_MODEL=claude-3-5-sonnet-latest
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

# === Embeddings (open source, corren en local, sin costo) ===
# Multilingüe: bueno para corpus en español. Alternativas: BAAI/bge-small-en-v1.5 (inglés).
EMBED_MODEL=intfloat/multilingual-e5-small

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64
# Estrategia: "sentence" (rápida, por defecto) o "semantic" (agrupa por similitud, más costosa)
CHUNK_STRATEGY=sentence

# === Retrieval ===
TOP_K=4

# === Vector store (Chroma local) ===
CHROMA_PATH=./data/processed/chroma
CHROMA_COLLECTION=rag_corpus

# === Datos ===
CORPUS_DIR=./data/raw
